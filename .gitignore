# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependências ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Testes ──────────────────────────────────────────────────────────────────
/coverage

# ─── Next.js ─────────────────────────────────────────────────────────────────
/.next/
/out/

# ─── Build de Produção ───────────────────────────────────────────────────────
/build

# ─── Misc ────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── Variáveis de Ambiente (NUNCA subir credenciais!) ────────────────────────
.env
.env.*
!.env.example

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Prisma ──────────────────────────────────────────────────────────────────
# Migrations geradas localmente (manter apenas se quiser versionar)
# prisma/migrations/

# ─── IDEs e Editores ─────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Sistema Operativo ───────────────────────────────────────────────────────
desktop.ini
ehthumbs.db
