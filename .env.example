
# ─── Base de Dados (Supabase PostgreSQL) ──────────────────────────────────────
# URL de conexão com connection pooling — obtida em: Supabase > Settings > Database > Connection string > Transaction
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# URL de conexão direta — usada pelo Prisma para migrações
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── NextAuth.js v5 
# Gere um segredo seguro com: openssl rand -base64 32
AUTH_SECRET="SUBSTITUA-POR-UM-SEGREDO-GERADO-ALEATORIAMENTE"

# URL base da aplicação (em produção substitua pelo domínio real)
NEXTAUTH_URL="http://localhost:3000"

# Ambiente (development | production)
NODE_ENV="development"
